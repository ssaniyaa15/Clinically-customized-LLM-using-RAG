# API (FastAPI) — pydantic-settings uses API_ prefix
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
API_CORS_ORIGINS=http://localhost:3000

# Web (Next.js)
# Server-side requests (RSC / route handlers): use internal URL in Docker (e.g. http://api:8000)
INTERNAL_API_URL=http://localhost:8000
# Browser-exposed base URL for client-side calls when added later
NEXT_PUBLIC_API_URL=http://localhost:8000
